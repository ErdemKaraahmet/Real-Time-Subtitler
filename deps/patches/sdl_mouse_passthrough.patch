+void SDL_SetWindowMousePassthrough(SDL_Window *window, bool passthrough)
+{
+    if (!_this->SetWindowMousePassthrough) {
+        SDL_Unsupported();
+        return;
+    }
+
+    _this->SetWindowMousePassthrough(_this, window, passthrough);
+}
